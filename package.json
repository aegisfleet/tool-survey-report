{
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "js-yaml": "^5.2.1"
  },
  "scripts": {
    "dev": "bundle exec jekyll serve --incremental --port 4000 --host 127.0.0.1",
    "dev:fast": "bundle exec jekyll serve --config _config.yml,_config.dev.yml --incremental --port 4000 --host 127.0.0.1",
    "lint": "biome lint . && pnpm lint:yaml",
    "lint:yaml": "node scripts/check_frontmatter.js",
    "format:check": "biome format --check .",
    "check": "biome ci .",
    "verify-report": "PYTHONPATH=. uv run scripts/run_checks.py",
    "update-wiki": "PYTHONPATH=. uv run scripts/update_wiki_links.py"
  }
}
